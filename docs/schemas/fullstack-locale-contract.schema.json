{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/fullstack-locale-contract.schema.json",
  "title": "Full-stack user-facing locale adapter contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profile", "adapters"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultLocale", "supportedLocales", "timezone", "currency"],
      "properties": {
        "defaultLocale": { "$ref": "#/$defs/locale" },
        "supportedLocales": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/locale" }
        },
        "timezone": { "type": "string", "minLength": 1 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    },
    "adapters": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layer", "adapterId", "sourceReference", "outputs"],
        "properties": {
          "layer": { "enum": ["frontend", "bff", "backend"] },
          "adapterId": { "type": "string", "minLength": 1 },
          "sourceReference": { "type": "string", "minLength": 1 },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/output" }
          }
        }
      }
    }
  },
  "$defs": {
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(?:-[A-Z][a-z]{3})?(?:-[A-Z]{2}|-[0-9]{3})?$"
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "locale",
        "documentLanguage",
        "htmlLang",
        "messages",
        "formatting",
        "accessibilityLabels",
        "rawBackendMessageExposed"
      ],
      "properties": {
        "locale": { "$ref": "#/$defs/locale" },
        "documentLanguage": { "$ref": "#/$defs/locale" },
        "htmlLang": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/locale" }
          ]
        },
        "messages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "userMessage", "internalDiagnostic"],
            "properties": {
              "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
              "userMessage": { "type": "string", "minLength": 1 },
              "internalDiagnostic": {
                "oneOf": [
                  { "type": "null" },
                  { "type": "string", "minLength": 1 }
                ]
              }
            }
          }
        },
        "formatting": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dateLocale", "numberLocale", "currency", "timezone"],
          "properties": {
            "dateLocale": { "$ref": "#/$defs/locale" },
            "numberLocale": { "$ref": "#/$defs/locale" },
            "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
            "timezone": { "type": "string", "minLength": 1 }
          }
        },
        "accessibilityLabels": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "rawBackendMessageExposed": { "const": false }
      }
    }
  }
}
