{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/stack-profile-fixtures.schema.json",
  "title": "Priority stack and database starter profile fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profileId", "priority", "topology", "applications", "database", "artifacts", "execution"],
  "properties": {
    "schemaVersion": {"const": 1},
    "profileId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "priority": {"enum": ["P0", "P1", "P2", "P3"]},
    "topology": {"enum": ["single-project", "workspace-monorepo"]},
    "applications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "root", "language", "runtime", "framework", "packageManager"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "type": {"enum": ["frontend", "backend", "fullstack", "shared"]},
          "root": {"type": "string", "minLength": 1},
          "language": {"type": "string", "minLength": 1},
          "runtime": {"$ref": "#/$defs/versioned"},
          "framework": {"$ref": "#/$defs/versioned"},
          "packageManager": {"$ref": "#/$defs/versioned"}
        }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "version", "role", "migrationPairs", "restoreEvidenceRef"],
      "properties": {
        "product": {"enum": ["none", "postgresql", "mysql", "sqlite", "sql-server", "mongodb"]},
        "version": {"type": ["string", "null"]},
        "role": {"enum": ["none", "primary"]},
        "migrationPairs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "up", "down"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "up": {"type": "string", "minLength": 1},
              "down": {"type": "string", "minLength": 1}
            }
          }
        },
        "restoreEvidenceRef": {"type": ["string", "null"]}
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "content"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "content": {"type": "string"}
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependencyInstall", "databaseMigration", "providerWrite", "productionDeploy"],
      "properties": {
        "dependencyInstall": {"const": "NOT_RUN"},
        "databaseMigration": {"const": "NOT_RUN"},
        "providerWrite": {"const": "NOT_RUN"},
        "productionDeploy": {"const": "NOT_RUN"}
      }
    }
  },
  "$defs": {
    "versioned": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    }
  }
}
