{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/policy-evidence.schema.json",
  "title": "Policy claim enforcement evidence profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "scope", "claims", "dataFlows", "enforcements", "evidence"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "scope": { "$ref": "#/$defs/scope" },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/claim" }
    },
    "dataFlows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dataFlow" }
    },
    "enforcements": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/enforcement" }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence" }
    }
  },
  "$defs": {
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["services", "regions", "dataCategories"],
      "properties": {
        "services": { "$ref": "#/$defs/nonEmptyStrings" },
        "regions": { "$ref": "#/$defs/nonEmptyStrings" },
        "dataCategories": { "$ref": "#/$defs/nonEmptyStrings" }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "statement",
        "ownerApproval",
        "applicability",
        "dataFlowRefs",
        "enforcementRefs",
        "evidenceRefs",
        "disposalContract"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^CLAIM-[A-Z0-9_-]+$" },
        "kind": { "enum": ["legal-applicability", "privacy", "retention", "disposal"] },
        "statement": { "type": "string", "minLength": 12 },
        "ownerApproval": {
          "type": "object",
          "additionalProperties": false,
          "required": ["role", "approvalReference", "reviewedAt", "validUntil"],
          "properties": {
            "role": { "type": "string", "minLength": 1 },
            "approvalReference": { "type": "string", "minLength": 1 },
            "reviewedAt": { "type": "string", "format": "date" },
            "validUntil": { "type": "string", "format": "date" }
          }
        },
        "applicability": { "$ref": "#/$defs/scope" },
        "dataFlowRefs": { "$ref": "#/$defs/nonEmptyStrings" },
        "enforcementRefs": { "$ref": "#/$defs/nonEmptyStrings" },
        "evidenceRefs": { "$ref": "#/$defs/nonEmptyStrings" },
        "disposalContract": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["maxRevocationDelaySeconds", "requiredAssertions"],
              "properties": {
                "maxRevocationDelaySeconds": { "type": "integer", "minimum": 0 },
                "requiredAssertions": {
                  "type": "array",
                  "uniqueItems": true,
                  "items": {
                    "enum": [
                      "post-disposal-read-denied",
                      "post-disposal-write-denied",
                      "token-reuse-denied",
                      "session-reuse-denied"
                    ]
                  }
                }
              }
            }
          ]
        }
      }
    },
    "dataFlow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "processingService", "region", "dataCategories", "destinations"],
      "properties": {
        "id": { "type": "string", "pattern": "^FLOW-[A-Z0-9_-]+$" },
        "source": { "type": "string", "minLength": 1 },
        "processingService": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 },
        "dataCategories": { "$ref": "#/$defs/nonEmptyStrings" },
        "destinations": { "$ref": "#/$defs/nonEmptyStrings" }
      }
    },
    "enforcement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "layer", "mechanism", "sourceReference"],
      "properties": {
        "id": { "type": "string", "pattern": "^ENF-[A-Z0-9_-]+$" },
        "layer": { "enum": ["server", "database", "provider"] },
        "mechanism": { "type": "string", "minLength": 1 },
        "sourceReference": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "precondition",
        "action",
        "expectedFailure",
        "result",
        "observedAt",
        "reference",
        "coversDataFlowRefs",
        "coversEnforcementRefs",
        "assertions"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^EVID-[A-Z0-9_-]+$" },
        "kind": { "enum": ["negative-test", "provider-attestation", "independent-inspection"] },
        "precondition": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "expectedFailure": { "type": "string", "minLength": 1 },
        "result": { "const": "PASS" },
        "observedAt": { "type": "string", "format": "date-time" },
        "reference": { "type": "string", "minLength": 1 },
        "coversDataFlowRefs": { "$ref": "#/$defs/nonEmptyStrings" },
        "coversEnforcementRefs": { "$ref": "#/$defs/nonEmptyStrings" },
        "assertions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "post-disposal-read-denied",
              "post-disposal-write-denied",
              "token-reuse-denied",
              "session-reuse-denied"
            ]
          }
        }
      }
    }
  }
}
