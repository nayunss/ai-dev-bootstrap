{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/common-ai-development-harness/capability-task.schema.json",
  "title": "Deterministic capability task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "kind",
    "requirementIds",
    "purpose",
    "input",
    "fixture",
    "permissions",
    "expectedOutcome",
    "graders",
    "trials",
    "limits",
    "stopConditions"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]{2,63}$" },
    "kind": { "enum": ["capability", "regression"] },
    "requirementIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^REQ-[0-9]{3}$" }
    },
    "purpose": { "type": "string", "minLength": 1 },
    "input": { "type": "string", "minLength": 1 },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "pattern": "^evals/fixtures/[A-Za-z0-9._/-]+$" },
        "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedTools", "network", "filesystem"],
      "properties": {
        "allowedTools": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["read", "test"] }
        },
        "network": { "const": "deny" },
        "filesystem": { "const": "isolated-fixture" }
      }
    },
    "expectedOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allGradersPass", "fixtureUnchanged"],
      "properties": {
        "allGradersPass": { "const": true },
        "fixtureUnchanged": { "type": "boolean" }
      }
    },
    "graders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "command", "expectedExitStatus", "timeoutMs"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
          "command": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string", "minLength": 1 }
          },
          "expectedExitStatus": { "type": "integer", "minimum": 0, "maximum": 255 },
          "timeoutMs": { "type": "integer", "minimum": 1, "maximum": 60000 }
        }
      }
    },
    "trials": { "type": "integer", "minimum": 1, "maximum": 20 },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxDurationMs", "maxToolCalls", "maxDiffBytes", "maxTokens", "maxCostUsd"],
      "properties": {
        "maxDurationMs": { "type": "integer", "minimum": 1, "maximum": 300000 },
        "maxToolCalls": { "type": "integer", "minimum": 1, "maximum": 100 },
        "maxDiffBytes": { "type": "integer", "minimum": 0 },
        "maxTokens": { "const": 0 },
        "maxCostUsd": { "const": 0 }
      }
    },
    "stopConditions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["grader-failure", "timeout", "limit-exceeded", "fixture-drift"] }
    }
  }
}
