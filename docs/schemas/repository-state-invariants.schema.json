{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/repository-state-invariants.schema.json",
  "title": "Repository state invariants profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedArtifacts", "checkOnlySourcePaths"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedArtifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "tree", "sha256", "sourceHashes"],
        "properties": {
          "path": { "$ref": "#/$defs/path" },
          "tree": { "const": "staged" },
          "sha256": { "$ref": "#/$defs/sha256" },
          "sourceHashes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "sha256"],
              "properties": {
                "path": { "$ref": "#/$defs/path" },
                "sha256": { "$ref": "#/$defs/sha256" }
              }
            }
          }
        }
      }
    },
    "checkOnlySourcePaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/path" }
    }
  },
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.env)(?!.*(?:^|/)\\.\\.?(?:/|$)).+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
