{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/development-environment-profile.schema.json",
  "title": "Development environment profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profileId", "status", "reviewedAt", "ownerRef", "repository", "applications", "settings", "collaboration", "ci", "artifacts", "deployments", "security", "decisions", "extensions"],
  "properties": {
    "schemaVersion": {"const": 1},
    "profileId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "status": {"enum": ["draft", "blocked", "approved", "superseded"]},
    "reviewedAt": {"type": "string", "format": "date"},
    "ownerRef": {"$ref": "#/$defs/reference"},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topology", "remoteRef"],
      "properties": {
        "topology": {"enum": ["single-project", "full-stack", "workspace-monorepo"]},
        "remoteRef": {"$ref": "#/$defs/reference"}
      }
    },
    "applications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "root", "language", "runtime", "framework", "manifest", "lockfile", "commands", "data"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "type": {"enum": ["frontend", "bff", "backend", "shared", "worker"]},
          "root": {"$ref": "#/$defs/path"},
          "language": {"type": "string", "minLength": 1},
          "runtime": {"$ref": "#/$defs/versionedTool"},
          "framework": {"$ref": "#/$defs/versionedTool"},
          "manifest": {"$ref": "#/$defs/path"},
          "lockfile": {"$ref": "#/$defs/path"},
          "commands": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {"$ref": "#/$defs/command"}
          },
          "data": {
            "type": "object",
            "additionalProperties": false,
            "required": ["primary", "migrationRef", "retentionEvidenceRef", "restoreEvidenceRef"],
            "properties": {
              "primary": {"type": "string", "minLength": 1},
              "migrationRef": {"type": ["string", "null"]},
              "retentionEvidenceRef": {"type": ["string", "null"]},
              "restoreEvidenceRef": {"type": ["string", "null"]}
            }
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["teamRequired", "projectRequired", "personalChoice", "reviewRequired", "prohibited"],
      "properties": {
        "teamRequired": {"$ref": "#/$defs/uniqueReferences"},
        "projectRequired": {"$ref": "#/$defs/uniqueReferences"},
        "personalChoice": {"$ref": "#/$defs/uniqueReferences"},
        "reviewRequired": {"$ref": "#/$defs/uniqueReferences"},
        "prohibited": {"$ref": "#/$defs/uniqueReferences"}
      }
    },
    "collaboration": {"$ref": "#/$defs/decisionArea"},
    "ci": {"$ref": "#/$defs/decisionArea"},
    "artifacts": {"$ref": "#/$defs/decisionArea"},
    "deployments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "environment", "providerRef", "configPath", "rollbackEvidenceRef"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "environment": {"enum": ["local", "ci", "preview", "staging", "production"]},
          "providerRef": {"$ref": "#/$defs/reference"},
          "configPath": {"type": ["string", "null"]},
          "rollbackEvidenceRef": {"type": ["string", "null"]}
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policyRef", "aiAdapters", "credentials"],
      "properties": {
        "policyRef": {"$ref": "#/$defs/reference"},
        "aiAdapters": {"type": "array", "items": {"$ref": "#/$defs/decisionArea"}},
        "credentials": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["referenceId", "ownerRef", "scope", "rotationPolicyRef"],
            "properties": {
              "referenceId": {"type": "string", "minLength": 1},
              "ownerRef": {"$ref": "#/$defs/reference"},
              "scope": {"type": "string", "minLength": 1},
              "rotationPolicyRef": {"$ref": "#/$defs/reference"}
            }
          }
        }
      }
    },
    "decisions": {"type": "array", "items": {"$ref": "#/$defs/decision"}},
    "extensions": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$"},
      "additionalProperties": true
    }
  },
  "$defs": {
    "path": {"type": "string", "minLength": 1},
    "reference": {"type": "string", "minLength": 1},
    "uniqueReferences": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/reference"}
    },
    "versionedTool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cwd", "executable", "argv", "network", "timeoutSeconds", "expectedArtifacts"],
      "properties": {
        "cwd": {"$ref": "#/$defs/path"},
        "executable": {"type": "string", "pattern": "^[A-Za-z0-9._+-]+$"},
        "argv": {"type": "array", "items": {"type": "string"}},
        "network": {"enum": ["deny", "approved"]},
        "timeoutSeconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "expectedArtifacts": {"type": "array", "items": {"$ref": "#/$defs/path"}}
      }
    },
    "decisionArea": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providerRef", "policyRef", "status"],
      "properties": {
        "providerRef": {"$ref": "#/$defs/reference"},
        "policyRef": {"$ref": "#/$defs/reference"},
        "status": {"enum": ["TBD", "pending", "approved", "not-applicable"]}
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "stage", "status", "ownerRef", "evidenceRef", "reviewedAt", "expiresAt", "blocker"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "stage": {"enum": ["local", "ci", "production"]},
        "status": {"enum": ["TBD", "pending", "approved", "rejected", "not-applicable"]},
        "ownerRef": {"type": ["string", "null"]},
        "evidenceRef": {"type": ["string", "null"]},
        "reviewedAt": {"type": ["string", "null"]},
        "expiresAt": {"type": ["string", "null"]},
        "blocker": {"type": ["string", "null"]}
      }
    }
  }
}
