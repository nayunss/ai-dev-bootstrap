{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/common-ai-development-harness/stack-quality-adapters.schema.json",
  "title": "Stack quality adapter profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "network", "applications"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "network": { "const": "deny" },
    "applications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "root", "language", "web", "gates"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
          "root": { "type": "string", "pattern": "^(\\.|[A-Za-z0-9][A-Za-z0-9._/-]*)$" },
          "language": { "enum": ["javascript", "java", "python"] },
          "web": { "type": "boolean" },
          "gates": {
            "type": "object",
            "additionalProperties": false,
            "required": ["formatter", "linter", "typecheck", "accessibility"],
            "properties": {
              "formatter": { "$ref": "#/$defs/executableGate" },
              "linter": { "$ref": "#/$defs/executableGate" },
              "typecheck": { "$ref": "#/$defs/executableGate" },
              "accessibility": {
                "oneOf": [
                  { "$ref": "#/$defs/executableGate" },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["mode", "rationale"],
                    "properties": {
                      "mode": { "const": "not-applicable" },
                      "rationale": { "type": "string", "minLength": 1 }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "executableGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "tool", "version", "executable", "versionArgs", "args", "timeoutMs"],
      "properties": {
        "mode": { "const": "required" },
        "tool": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$" },
        "executable": { "type": "string", "pattern": "^\\.tools/quality/bin/[A-Za-z0-9._-]+$" },
        "versionArgs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "args": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "timeoutMs": { "type": "integer", "minimum": 1, "maximum": 120000 }
      }
    }
  }
}
