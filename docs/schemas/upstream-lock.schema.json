{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/upstream-lock.schema.json",
  "title": "Canonical upstream adoption lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "source",
    "manifestSha256",
    "contentSha256",
    "files"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "upstream-lock"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "release",
        "commit",
        "archiveSha256"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "release": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "archiveSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "manifestSha256": {
      "$ref": "#/$defs/sha256"
    },
    "contentSha256": {
      "$ref": "#/$defs/sha256"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
