{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/delivery-evidence-states.schema.json",
  "title": "Provider-neutral delivery evidence states",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "deliveryId", "deliveryRef", "states"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "deliveryId": { "type": "string", "pattern": "^DELIVERY-[A-Z0-9_-]+$" },
    "deliveryRef": { "type": "string", "minLength": 1 },
    "states": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/state" }
    }
  },
  "$defs": {
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "status", "blockedReason", "evidence", "behavior", "approval"],
      "properties": {
        "stage": {
          "enum": [
            "created",
            "pushed",
            "ci-triggered",
            "ci-passed",
            "deployed",
            "healthy",
            "behavior-verified",
            "production-approved"
          ]
        },
        "status": { "enum": ["PASS", "FAIL", "BLOCKED", "NOT-RUN"] },
        "blockedReason": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        },
        "behavior": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["precondition", "input", "assertions", "negativePath", "cleanup"],
              "properties": {
                "precondition": { "type": "string", "minLength": 1 },
                "input": { "type": "string", "minLength": 1 },
                "assertions": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": { "type": "string", "minLength": 1 }
                },
                "negativePath": { "type": "string", "minLength": 1 },
                "cleanup": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "approval": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["humanAttestation", "reviewerRole", "reviewerId", "approvalReference", "approvedAt"],
              "properties": {
                "humanAttestation": { "const": true },
                "reviewerRole": { "type": "string", "minLength": 1 },
                "reviewerId": { "type": "string", "minLength": 1 },
                "approvalReference": { "type": "string", "minLength": 1 },
                "approvedAt": { "type": "string", "format": "date-time" }
              }
            }
          ]
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reference", "observedAt", "scope", "deliveryRef"],
      "properties": {
        "kind": {
          "enum": [
            "commit-record",
            "remote-receipt",
            "ci-run",
            "ci-conclusion",
            "deployment-record",
            "health-assertion",
            "behavior-assertion",
            "human-approval",
            "failure-record"
          ]
        },
        "reference": { "type": "string", "minLength": 1 },
        "observedAt": { "type": "string", "format": "date-time" },
        "scope": { "type": "string", "minLength": 1 },
        "deliveryRef": { "type": "string", "minLength": 1 }
      }
    }
  }
}
