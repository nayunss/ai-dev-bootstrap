{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/distributed-pilot-result.schema.json",
  "title": "Distributed downstream pilot result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "campaignId",
    "pilotId",
    "trialId",
    "tester",
    "executedAt",
    "upstream",
    "downstream",
    "environment",
    "aiProvenance",
    "requirementIds",
    "outcomes",
    "negativeRollbackFixtures",
    "findings",
    "unverified",
    "cost",
    "attestation",
    "review",
    "reportedStatus"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "campaignId": { "type": "string", "minLength": 1 },
    "pilotId": { "type": "string", "minLength": 1 },
    "trialId": { "type": "string", "minLength": 1 },
    "tester": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "roles"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["tester", "maintainer", "coordinator", "reviewer"] }
        }
      }
    },
    "executedAt": { "type": "string", "format": "date-time" },
    "upstream": { "$ref": "#/$defs/upstream" },
    "downstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commitSha",
        "repositoryFingerprint",
        "workspaceId",
        "resourceIsolationId",
        "cleanStart",
        "independentGitRepository"
      ],
      "properties": {
        "commitSha": { "$ref": "#/$defs/sha1" },
        "repositoryFingerprint": { "$ref": "#/$defs/sha256" },
        "workspaceId": { "type": "string", "minLength": 1 },
        "resourceIsolationId": { "type": "string", "minLength": 1 },
        "cleanStart": { "type": "boolean" },
        "independentGitRepository": { "type": "boolean" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "architecture", "stack", "ciProvider", "deployProvider"],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "stack": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 }
            }
          }
        },
        "ciProvider": { "type": "string", "minLength": 1 },
        "deployProvider": { "type": "string", "minLength": 1 }
      }
    },
    "aiProvenance": { "$ref": "#/$defs/aiProvenance" },
    "requirementIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^REQ-[0-9]{3}$" }
    },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/outcome" }
    },
    "negativeRollbackFixtures": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fixture" }
    },
    "findings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "feedbackReference"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "feedbackReference": { "$ref": "#/$defs/evidenceReference" }
      }
    },
    "unverified": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["durationMinutes", "tokenUsage", "externalCost", "measurementNotes"],
      "properties": {
        "durationMinutes": { "type": "number", "minimum": 0 },
        "tokenUsage": { "type": ["integer", "null"], "minimum": 0 },
        "externalCost": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["amount", "currency"],
              "properties": {
                "amount": { "type": "number", "minimum": 0 },
                "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
              }
            }
          ]
        },
        "measurementNotes": { "type": "string", "minLength": 1 }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "graderAssetsModified",
        "previousTesterResultsAccessed",
        "productionDataUsed",
        "secretsIncluded",
        "submittedBy",
        "submittedAt"
      ],
      "properties": {
        "graderAssetsModified": { "const": false },
        "previousTesterResultsAccessed": { "const": false },
        "productionDataUsed": { "const": false },
        "secretsIncluded": { "const": false },
        "submittedBy": { "type": "string", "minLength": 1 },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewerId", "reviewedAt", "evidenceReference"],
      "properties": {
        "status": { "enum": ["approved", "pending", "rejected"] },
        "reviewerId": { "type": "string", "minLength": 1 },
        "reviewedAt": { "type": "string", "minLength": 1 },
        "evidenceReference": { "$ref": "#/$defs/evidenceReference" }
      }
    },
    "reportedStatus": { "enum": ["PASS", "FAIL", "BLOCKED", "NOT-RUN"] }
  },
  "$defs": {
    "sha1": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "ref", "commitSha", "releaseChecksum"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "commitSha": { "$ref": "#/$defs/sha1" },
        "releaseChecksum": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "const": "not-published" }
          ]
        }
      }
    },
    "aiProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "toolSurface",
        "toolVersion",
        "modelDisplayName",
        "modelId",
        "modeProfile",
        "adapters",
        "permissions",
        "evidenceLevel",
        "verificationReference"
      ],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "toolSurface": { "type": "string", "minLength": 1 },
        "toolVersion": { "type": "string", "minLength": 1 },
        "modelDisplayName": { "type": "string", "minLength": 1 },
        "modelId": { "type": "string", "minLength": 1 },
        "modeProfile": { "type": "string", "minLength": 1 },
        "adapters": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "permissions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["filesystem", "network", "approval"],
          "properties": {
            "filesystem": { "type": "string", "minLength": 1 },
            "network": { "type": "string", "minLength": 1 },
            "approval": { "type": "string", "minLength": 1 }
          }
        },
        "evidenceLevel": { "enum": ["verified", "tester-declared", "undisclosed"] },
        "verificationReference": { "$ref": "#/$defs/evidenceReference" }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "status", "command", "exitStatus", "evidenceReferences", "notes"],
      "properties": {
        "gate": { "type": "string", "minLength": 1 },
        "status": { "enum": ["PASS", "FAIL", "BLOCKED", "NOT-RUN"] },
        "command": { "type": "string", "minLength": 1 },
        "exitStatus": { "type": ["integer", "null"] },
        "evidenceReferences": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidenceReference" }
        },
        "notes": { "type": "string" }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture", "status", "expected", "observed", "cleanupStatus", "evidenceReferences"],
      "properties": {
        "fixture": { "type": "string", "minLength": 1 },
        "status": { "enum": ["PASS", "FAIL", "BLOCKED", "NOT-RUN"] },
        "expected": { "type": "string", "minLength": 1 },
        "observed": { "type": "string", "minLength": 1 },
        "cleanupStatus": { "enum": ["PASS", "FAIL", "BLOCKED", "NOT-RUN"] },
        "evidenceReferences": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidenceReference" }
        }
      }
    },
    "evidenceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference", "sha256"],
      "properties": {
        "reference": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
