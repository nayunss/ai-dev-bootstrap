{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/common-ai-development-harness/dependency-bootstrap.schema.json",
  "title": "Downstream dependency bootstrap profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "applications"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "applications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "root", "adapter", "version", "manifest", "lockfile"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
          "root": { "type": "string", "pattern": "^(\\.|[A-Za-z0-9][A-Za-z0-9._/-]*)$" },
          "adapter": { "enum": ["npm", "pnpm", "yarn", "maven", "gradle", "python"] },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$" },
          "manifest": { "type": "string", "minLength": 1 },
          "lockfile": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
