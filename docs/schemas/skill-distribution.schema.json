{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/common-ai-development-harness/skill-distribution.schema.json",
  "title": "Portable skill distribution manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "release", "core", "optional", "toolAdapters", "reviewedPlugins"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "requiredCoreVersion"],
      "properties": {
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "requiredCoreVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      }
    },
    "core": { "$ref": "#/$defs/skills" },
    "optional": { "$ref": "#/$defs/skills" },
    "toolAdapters": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version", "canonicalRoot", "targetRoot", "sha256"],
        "properties": {
          "id": { "enum": ["codex", "claude-code", "github-copilot"] },
          "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "canonicalRoot": { "const": ".ai/skills" },
          "targetRoot": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/hash" }
        }
      }
    },
    "reviewedPlugins": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version", "source", "sha256", "license", "permissions", "network", "telemetry", "catalogState", "installApproved"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "version": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "pattern": "^https://" },
          "sha256": { "$ref": "#/$defs/hash" },
          "license": { "type": "string", "minLength": 1 },
          "permissions": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "network": { "enum": ["none", "review-required"] },
          "telemetry": { "enum": ["none", "disabled-and-verified", "review-required"] },
          "catalogState": { "const": "reviewed-catalog-only" },
          "installApproved": { "const": false }
        }
      }
    }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version", "source", "packageSha256", "license", "risk", "dependencies", "files"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "source": { "type": "string", "minLength": 1 },
          "packageSha256": { "$ref": "#/$defs/hash" },
          "license": { "type": "string", "minLength": 1 },
          "risk": { "enum": ["markdown-only", "project-script"] },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "version"],
              "properties": {
                "id": { "type": "string" },
                "version": { "type": "string" }
              }
            }
          },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "sha256"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "sha256": { "$ref": "#/$defs/hash" }
              }
            }
          }
        }
      }
    }
  }
}
