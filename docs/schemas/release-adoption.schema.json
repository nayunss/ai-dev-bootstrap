{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/common-ai-development-harness/release-adoption.schema.json",
  "title": "CLI and web shared release adoption contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "release", "components", "selection", "execution"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "commit", "archivePath", "archiveSha256", "manifestSha256"],
      "properties": {
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "archivePath": { "type": "string", "minLength": 1 },
        "archiveSha256": { "$ref": "#/$defs/hash" },
        "manifestSha256": { "$ref": "#/$defs/hash" }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stackProfile", "skillDistribution"],
      "properties": {
        "stackProfile": { "$ref": "#/$defs/component" },
        "skillDistribution": { "$ref": "#/$defs/component" }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["optionalSkills", "adapters"],
      "properties": {
        "optionalSkills": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "adapters": {
          "type": "array",
          "items": { "enum": ["codex", "claude-code", "github-copilot"] },
          "uniqueItems": true
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["network", "telemetry", "dependencyInstall", "databaseMigration", "providerWrite", "productionDeploy"],
      "properties": {
        "network": { "const": "NOT_RUN" },
        "telemetry": { "const": "DISABLED" },
        "dependencyInstall": { "const": "NOT_RUN" },
        "databaseMigration": { "const": "NOT_RUN" },
        "providerWrite": { "const": "NOT_RUN" },
        "productionDeploy": { "const": "NOT_RUN" }
      }
    }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/hash" }
      }
    }
  }
}
