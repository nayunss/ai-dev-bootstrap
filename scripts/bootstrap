#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
MODE=${1:-preview}

case "$MODE" in
  preview)
    cat <<'EOF'
Bootstrap preview
- Scope: project-local files and .tools only
- Global AI, Git, shell and package-manager settings: unchanged
- Corepack fallback and floating latest versions: forbidden
- Dependency lifecycle scripts: disabled by default
- Deployment install: approved exact-version build-script allowlist and separate provider-equivalent Eval required
- Git/Vercel: verified commit identity and duplicate repository integration check required before push/import
- AI adapters: AGENTS.md and CLAUDE.md reference the shared .ai engineering and security standards
- Optional AI adapters: preview and explicitly approve only selected Codex or Claude Code files
- Security binaries: exact versions and checksums from .ai/manifests/security-tools.yaml
- Playwright browser binaries: excluded; separate preview and Human-in-the-loop approval required
- Husky: excluded until the downstream environment and quality commands pass
- Application inventory: recursively detect root and nested manifests; multi-application repositories must declare docs/development-environment.md JSON inventory
- Stack evolution: preserve existing applications and preview only new application plus shared CodeSight, EditorConfig, adapter, hook, CI and deployment drift
- Production readiness onboarding: review legal/privacy owner, retention/disposal policy owner, and multi-instance rate-limit strategy
- Readiness retrofit: after reviewing applicability, use scripts/bootstrap readiness TARGET; existing policy is never overwritten and unresolved values block Production

Apply reviewed security tools only: scripts/bootstrap security-tools
Install locked dependencies with scripts disabled and strict peers:
  scripts/bootstrap dependencies /absolute/path/to/project --allow-network
Validate a downstream project: scripts/validate /absolute/path/to/project
Validate a readiness profile: node scripts/validate-production-readiness.mjs PROFILE --expect-blocked
Add a missing readiness profile without overwriting existing policy:
  scripts/bootstrap readiness /absolute/path/to/project
Preview selected AI adapters without changing the target:
  scripts/bootstrap adapters preview /absolute/path/to/project codex,claude-code
Apply or uninstall reviewed adapters:
  scripts/bootstrap adapters apply /absolute/path/to/project codex --approve
  scripts/bootstrap adapters uninstall /absolute/path/to/project codex --approve
Validate adapter generator, source and target hashes:
  scripts/bootstrap adapters validate /absolute/path/to/project
Online vulnerability audit: scripts/validate /absolute/path/to/project --online-audit
EOF
    if [ -n "${2:-}" ]; then
      TARGET=$(CDPATH= cd -- "$2" && pwd)
      node "$ROOT/scripts/preview-applications.mjs" "$TARGET"
    fi
    ;;
  security-tools)
    "$ROOT/scripts/bootstrap-security-tools"
    ;;
  dependencies)
    TARGET=${2:-}
    NETWORK=${3:-}
    if [ -z "$TARGET" ] || [ "$NETWORK" != "--allow-network" ]; then
      echo "Dependency install requires a target and explicit --allow-network approval." >&2
      exit 2
    fi
    TARGET=$(CDPATH= cd -- "$TARGET" && pwd)
    MANAGER=$(node -e 'const p=require(process.argv[1]); process.stdout.write(String(p.packageManager || ""))' "$TARGET/package.json")
    case "$MANAGER" in
      pnpm@*)
        NODE="$TARGET/.tools/node/bin/node"
        PNPM="$TARGET/.tools/pnpm/package/bin/pnpm.cjs"
        [ -x "$NODE" ] && [ -f "$PNPM" ] || {
          echo "Reviewed project-local Node and pnpm are required; Corepack fallback is forbidden." >&2
          exit 1
        }
        (cd "$TARGET" && "$NODE" "$PNPM" install --ignore-scripts --strict-peer-dependencies --store-dir "$TARGET/.tools/pnpm-store")
        ;;
      npm@*)
        EXPECTED=${MANAGER#npm@}
        ACTUAL=$(npm --version)
        [ "$EXPECTED" = "$ACTUAL" ] || {
          echo "npm version mismatch: expected $EXPECTED, found $ACTUAL." >&2
          exit 1
        }
        (cd "$TARGET" && npm ci --ignore-scripts --strict-peer-deps)
        ;;
      *)
        echo "Unsupported or unpinned packageManager: $MANAGER" >&2
        exit 1
        ;;
    esac
    node "$ROOT/scripts/validate-downstream.mjs" "$TARGET"
    ;;
  readiness)
    TARGET=${2:-}
    if [ -z "$TARGET" ]; then
      echo "Readiness materialization requires a target project." >&2
      exit 2
    fi
    TARGET=$(CDPATH= cd -- "$TARGET" && pwd)
    node "$ROOT/scripts/materialize-production-readiness.mjs" "$TARGET"
    ;;
  adapters)
    ACTION=${2:-}
    TARGET=${3:-}
    SELECTION=${4:-}
    APPROVAL=${5:-}
    if [ -z "$ACTION" ] || [ -z "$TARGET" ]; then
      echo "Adapter management requires an action and target project." >&2
      exit 2
    fi
    TARGET=$(CDPATH= cd -- "$TARGET" && pwd)
    if [ "$ACTION" = "validate" ]; then
      node "$ROOT/scripts/manage-adapters.mjs" validate "$TARGET"
    else
      node "$ROOT/scripts/manage-adapters.mjs" "$ACTION" "$TARGET" "$SELECTION" "$APPROVAL"
    fi
    ;;
  *)
    echo "Usage: scripts/bootstrap [preview [TARGET]|security-tools|dependencies TARGET --allow-network|readiness TARGET|adapters ACTION TARGET [codex,claude-code] [--approve]]" >&2
    exit 2
    ;;
esac
