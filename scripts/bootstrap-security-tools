#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
TOOLS="$ROOT/.tools"
BIN="$TOOLS/bin"
mkdir -p "$BIN"

OS=$(uname -s)
ARCH=$(uname -m)
case "$OS/$ARCH" in
  Darwin/arm64)
    GITLEAKS_ASSET=gitleaks_8.30.1_darwin_arm64.tar.gz
    GITLEAKS_SHA=b40ab0ae55c505963e365f271a8d3846efbc170aa17f2607f13df610a9aeb6a5
    OPENGREP_ASSET=opengrep_osx_arm64
    OPENGREP_SHA=6105ab78eca041fcb9f83055939088ba8f96a6cb66683ceced39652938b217ce
    ;;
  Linux/x86_64)
    GITLEAKS_ASSET=gitleaks_8.30.1_linux_x64.tar.gz
    GITLEAKS_SHA=551f6fc83ea457d62a0d98237cbad105af8d557003051f41f3e7ca7b3f2470eb
    OPENGREP_ASSET=opengrep_manylinux_x86
    OPENGREP_SHA=45bcd58440e397ed52c50e953ccf5948909ea77087c9186fc7d277216f62e319
    ;;
  *)
    echo "Unsupported platform for locked security binaries: $OS/$ARCH" >&2
    echo "Add an audited asset and checksum to scripts/bootstrap-security-tools." >&2
    exit 1
    ;;
esac

if [ ! -x "$BIN/gitleaks" ]; then
  ARCHIVE="$TOOLS/$GITLEAKS_ASSET"
  curl --fail --location --proto '=https' --tlsv1.2 \
    "https://github.com/gitleaks/gitleaks/releases/download/v8.30.1/$GITLEAKS_ASSET" \
    --output "$ARCHIVE"
  printf '%s  %s\n' "$GITLEAKS_SHA" "$ARCHIVE" | shasum -a 256 -c -
  tar -xzf "$ARCHIVE" -C "$BIN" gitleaks
fi

if [ ! -x "$BIN/opengrep" ]; then
  OPENGREP_DOWNLOAD="$TOOLS/$OPENGREP_ASSET"
  curl --fail --location --proto '=https' --tlsv1.2 \
    "https://github.com/opengrep/opengrep/releases/download/v1.22.0/$OPENGREP_ASSET" \
    --output "$OPENGREP_DOWNLOAD"
  printf '%s  %s\n' "$OPENGREP_SHA" "$OPENGREP_DOWNLOAD" | shasum -a 256 -c -
  cp "$OPENGREP_DOWNLOAD" "$BIN/opengrep"
  chmod +x "$BIN/opengrep"
fi

mkdir -p "$TOOLS/runtime-home" "$TOOLS/runtime-cache"

"$ROOT/scripts/security-check" verify-tools
