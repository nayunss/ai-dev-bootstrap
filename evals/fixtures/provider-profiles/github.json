{
  "schemaVersion": 1,
  "profileId": "github-synthetic",
  "adapter": {"id": "github", "mode": "synthetic-read-only", "capabilities": ["git-read", "change-request-preview", "branch-policy-preview", "pipeline-preview", "artifact-preview", "deployment-preview"]},
  "hosting": {"provider": "github", "host": "github.com", "namespace": "example-org", "repository": "example-repo", "canonicalRemote": "upstream", "fetchUrl": "https://github.com/example-org/example-repo.git", "pushUrl": "ssh://git@github.com/example-org/example-repo.git", "defaultBranch": "main", "visibility": "private", "changeRequestMode": "pull-request", "credentialRef": "credentials/github-project"},
  "branchReview": {
    "strategy": "short-lived-feature",
    "mergeMethods": ["squash"],
    "forcePush": false,
    "requiredChecks": ["quality", "security"],
    "riskPolicies": [
      {"risk": "normal", "minimumApprovals": 1, "requiredRoles": ["maintainer"], "selfReview": false},
      {"risk": "dependency", "minimumApprovals": 1, "requiredRoles": ["supply-chain"], "selfReview": false},
      {"risk": "security", "minimumApprovals": 1, "requiredRoles": ["security"], "selfReview": false},
      {"risk": "release", "minimumApprovals": 1, "requiredRoles": ["release"], "selfReview": false},
      {"risk": "production", "minimumApprovals": 1, "requiredRoles": ["production"], "selfReview": false},
      {"risk": "database", "minimumApprovals": 1, "requiredRoles": ["database"], "selfReview": false},
      {"risk": "destructive", "minimumApprovals": 1, "requiredRoles": ["independent-reviewer"], "selfReview": false}
    ],
    "emergency": {"enabled": false, "approverRole": null, "expiresAt": null, "postReviewRequired": true, "rollbackRef": null}
  },
  "ci": {"provider": "github-actions", "configPath": ".github/workflows/security.yml", "ownerRef": "owners/ci", "credentialRef": "credentials/github-actions", "permissions": ["contents-read", "oidc-write"], "network": "approved-hosts", "requiredOutcomes": ["immutable-checkout", "quality", "test", "security", "provenance", "artifact-integrity", "fail-closed"]},
  "artifacts": {"provider": "github-artifact", "configPath": ".github/workflows/security.yml", "ownerRef": "owners/release", "credentialRef": null, "permissions": ["artifact-write"], "network": "approved-hosts", "requiredOutcomes": ["sanitized-evidence"], "integrity": "sha256", "retentionDays": 14},
  "deployments": [{"environment": "production", "provider": "vercel", "applicationRoot": "web", "configPath": "deploy/vercel.json", "promotion": "human-approved", "rollbackRef": "docs/rollback.md", "credentialRef": "credentials/vercel-production"}]
}
